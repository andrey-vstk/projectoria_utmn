# Shared
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplom?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=8h
JWT_COOKIE_NAME=diplom_access
CSRF_COOKIE_NAME=diplom_csrf

# Admin bootstrap
SEED_ADMIN_EMAIL=admin@utmn.local
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Администратор

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Платформа ТюмГУ <noreply@utmn.local>"

# LLM
# mock | external | n8n
LLM_PROVIDER=mock
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# n8n integration
N8N_WEBHOOK_URL=
N8N_EMAIL_WORKFLOW_URL=
# example: http://localhost:5678/webhook/llm-analyze
# Docker Compose: http://n8n:5678/webhook/llm-analyze
# Local (без Docker): http://localhost:5678/webhook/llm-analyze
N8N_LLM_WEBHOOK_URL=
N8N_LLM_TIMEOUT_MS=120000

# Public links
PUBLIC_BASE_URL=http://localhost:3000

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=20
