# Shared
NODE_ENV=production
APP_URL=https://projectoria-utmn.ru
API_URL=https://projectoria-utmn.ru/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projectoria?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=8h
JWT_COOKIE_NAME=projectoria_access
CSRF_COOKIE_NAME=projectoria_csrf

# Admin bootstrap
SEED_ADMIN_EMAIL=admin@utmn.local
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Администратор

# SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Проектория <your-email@example.com>"

# LLM
# mock | external | n8n
LLM_PROVIDER=mock
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=qwen3.6:35b
OLLAMA_BASE_URL=http://10.255.243.25:11434
OLLAMA_CHECK_TIMEOUT_MS=10000

# n8n integration
N8N_WEBHOOK_URL=
N8N_EMAIL_WORKFLOW_URL=
# example: http://localhost:5678/webhook/llm-analyze
# Docker Compose: http://n8n:5678/webhook/llm-analyze
# Local (без Docker): http://localhost:5678/webhook/llm-analyze
N8N_LLM_WEBHOOK_URL=
N8N_OLLAMA_PROXY_CHAT_URL=http://api:3001/internal/ollama/api/chat
N8N_LLM_TIMEOUT_MS=1800000

# Public links
PUBLIC_BASE_URL=https://projectoria-utmn.ru

# Web
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://api:3001

# Reverse proxy
CADDY_DOMAIN=projectoria-utmn.ru
CADDY_EMAIL=admin@example.com

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=20
